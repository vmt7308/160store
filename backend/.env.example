# Lưu ý đổi tên file .env.example thành .env

PORT= # Port, ví dụ: 5000
JWT_SECRET= # Chuỗi bảo mật (bạn đặt gì cũng được, ví dụ: 160storeChuoiPhanPhoiThoiTrangNamChinhHang)

FRONTEND_URL= # Link dự án sau khi deploy, ví dụ: https://160store-frontend.vercel.app
DB_SERVER= # Server database
DB_DATABASE= # Tên database sử dụng
DB_USER= # Tài khoản database
DB_PASSWORD= # Mật khẩu database
DB_PORT= # Port MSSQL, nếu là mặt định set 1433

EMAIL_USER= # Email của bạn, ví dụ: vmt7308@gmail.com
EMAIL_PASS= # Mã bí mật của email, vào email cá nhân của bạn để lấy

# Tắt thông báo dotenv
DOTENV_CONFIG_QUIET=true

# Thêm keys cho 10 free AI APIss
# Chỉ cần truy cập link tương ứng, đăng ký tài khoản là có key (dùng key free đủ dùng, không cần trả phí)
GEMINI_API_KEY= # Google AI Studio, link: https://aistudio.google.com/app/api-keys?referrer=grok.com
HF_API_KEY= # Hugging Face, link: https://huggingface.co/settings/tokens?referrer=grok.com
REPLICATE_API_KEY= # Replicate.ai free tier, link: https://replicate.com/account/api-tokens?referrer=grok.com
TOGETHER_API_KEY= # Together.ai free, link: https://api.together.xyz/
GROQ_API_KEY= # Groq free tier, link: https://console.groq.com/keys?referrer=grok.com
COHERE_API_KEY= # Cohere free tier, link: https://dashboard.cohere.com/api-keys?referrer=grok.com
PERPLEXITY_API_KEY= # Perplexity free (if available), link: https://www.perplexity.ai/account/api/group
MISTRAL_API_KEY= # Mistral AI free tier, link: https://console.mistral.ai/home?workspace_dialog=apiKeys
LLAMA_API_KEY=  # Llama via free endpoint, Không cần key riêng. Code dùng Groq/Together để chạy Llama models miễn phí.
AYA_API_KEY=  # Cohere Aya free, Aya là model của Cohere → dùng chung key Cohere. Không cần key riêng.
FPT_API_KEY= # Đăng ký miễn phí tại https://console.fpt.ai/getting-started
